# Copy to deploy/logrunner-prod/.env.prod locally. This file contains live
# deployment secrets and is intentionally gitignored.

# SSH target for the VM that will run NanoClaw and Docker.
LOGRUNNER_SSH_TARGET=root@203.0.113.10
LOGRUNNER_SSH_KEY=/Users/danielbriskin/.ssh/hetzner_logrunner_prod
LOGRUNNER_REMOTE_DIR=/opt/logrunner-prod
LOGRUNNER_SERVICE_USER=logrunner

# NanoClaw source. Use a branch, tag, or commit reachable by the remote VM.
NANOCLAW_REPO=https://github.com/dbxe/nanoclaw.git
NANOCLAW_REF=deploy/logrunner-prod

# Public Discord channel route. For a server channel use:
# discord:<guild-id>:<channel-id>
LOGRUNNER_DISCORD_PLATFORM_ID=discord:000000000000000000:111111111111111111
LOGRUNNER_AGENT_GROUP_ID=ag-logrunner-prod
LOGRUNNER_CLI_MESSAGING_GROUP_ID=mg-logrunner-prod-cli
LOGRUNNER_AGENT_PROVIDER=opencode
LOGRUNNER_AGENT_FOLDER=logrunner-prod
LOGRUNNER_AGENT_NAME="Logrunner Prod"

# Discord app credentials for the live bot.
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=

# Official OpenAI endpoint for the short-lived demo A/B test. If you paste any
# full /chat/completions URL, deploy derives OPENAI_BASE_URL by stripping the
# final /chat/completions segment.
OPENAI_CHAT_COMPLETIONS_URL=https://api.openai.com/v1/chat/completions
OPENAI_BASE_URL=
# Defaults to Keychain item DEMO_OPENAI_API_KEY on macOS. Set to env to use
# OPENAI_API_KEY from this file or the shell instead.
OPENAI_API_KEY_SOURCE=keychain
OPENAI_API_KEY_KEYCHAIN_ITEM=DEMO_OPENAI_API_KEY
OPENAI_API_KEY=
OPENAI_ONECLI_SECRET_NAME="Logrunner OpenAI-Compatible Endpoint"
OPENAI_ONECLI_PATH_PATTERN=/v1/*
OPENCODE_PROVIDER=openai
OPENCODE_PROVIDER_NAME="OpenAI"
OPENCODE_PROVIDER_PACKAGE=@ai-sdk/openai-compatible
# OpenCode model format is <opencode-provider>/<backend-model-id>.
OPENCODE_MODEL=openai/gpt-5.4-mini
OPENCODE_SMALL_MODEL=openai/gpt-5.4-mini
OPENCODE_MODEL_CONTEXT_LIMIT=400000
OPENCODE_MODEL_OUTPUT_LIMIT=8192

# MultiBaas live deployments. Prefer MULTIBAAS_BACKENDS_FILE when the demo spans
# multiple chains/backends; it should contain one profile per live backend with
# baseUrl/apiKey pairs. MULTIBAAS_PROFILE selects the default profile for
# single-backend tools. MULTIBAAS_BASE_URL/API_KEY are still supported as a
# single-backend fallback.
MULTIBAAS_BACKENDS_FILE=.multibaas/backends.local.json
MULTIBAAS_PROFILE=mainnet-remote
MULTIBAAS_BASE_URL=https://multibaas.example.com
MULTIBAAS_API_KEY=
MULTIBAAS_ONECLI_SECRET_NAME="Logrunner MultiBaas"
MULTIBAAS_ONECLI_PATH_PATTERN=/api/v0/*

# OneCLI gateway used by NanoClaw to inject credentials into agent containers.
# Leave ONECLI_URL blank for the deploy to install/reuse a gateway on the VM.
ONECLI_URL=
ONECLI_API_KEY=
LOGRUNNER_REINSTALL_ONECLI=0

# Required for MultiBaas event callbacks and balance-watch alerts.
# The deploy can store a newly generated MultiBaas secret in shared VM state;
# set MULTIBAAS_WEBHOOK_SECRET only if you already created the webhook manually.
LOGRUNNER_WEBHOOK_PUBLIC_URL=https://203.0.113.10.sslip.io/webhooks/multibaas
LOGRUNNER_WEBHOOK_LABEL=logrunner-prod-runtime-events
MULTIBAAS_WEBHOOK_SECRET=
LOGRUNNER_ENABLE_CADDY=1
# Use compact instructions for low-token-budget OpenAI-compatible endpoints.
LOGRUNNER_NANOCLAW_INSTRUCTION_PROFILE=
